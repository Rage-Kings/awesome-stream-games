; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited.
; See https://docs.godotengine.org/en/stable/classes/class_projectsettings.html

[application]

config/name="Stream Game"
config/description="Набор мини-игр для стримеров. Зрители участвуют через чат Twitch и Kick."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

GameManager="*res://src/autoload/game_manager.gd"
ChatManager="*res://src/autoload/chat_manager.gd"
PlayerManager="*res://src/autoload/player_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="forward_plus"
